# Plantilla de credenciales privadas para Brami3D.
# Copia este archivo a `.env` y rellena los valores reales.
# El `.env` está en .gitignore: NUNCA se sube al repo público.
#
# OJO: las claves del frontend (SUPA_KEY publishable, VAPID_PUBLIC, etc.)
# son PÚBLICAS por diseño y NO van aquí — viven embebidas en los .html.
# Aquí solo van SECRETOS reales que usa el tooling local (p. ej. el MCP de Meta).

# --- Meta / Facebook / Instagram (MCP) ---
# Token de acceso de larga duración (System User token del Business Manager).
META_ACCESS_TOKEN=
# ID de la App creada en developers.facebook.com
META_APP_ID=
# Secreto de la App (Configuración -> Básica -> Clave secreta de la app)
META_APP_SECRET=
# ID de la cuenta publicitaria para Ads (formato act_XXXXXXXXXX)
META_AD_ACCOUNT_ID=
# ID de la Página de Facebook (Brami3D)
META_PAGE_ID=
# ID de la cuenta de Instagram profesional (brami3d.app)
META_IG_USER_ID=
